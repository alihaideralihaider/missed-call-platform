{
  "project": "saanaos",
  "stack": "nextjs-cloudflare-supabase",
  "evidence": {
    "path": "docs/reviews"
  },
  "blockOn": ["Critical", "High"],
  "defaultReviews": ["plan", "guard"],
  "reviewPacks": [
    "security",
    "tenant-boundary",
    "vault-integrity",
    "runtime-binding",
    "vault-recovery",
    "payments",
    "sms-compliance",
    "restaurant-ux",
    "browser-qa",
    "deploy-canary"
  ],
  "routing": [
    {
      "review": "security",
      "skill": "saana-security-review",
      "reason": "Auth, login, admin, API, Supabase, or webhook paths changed.",
      "match": ["auth", "login", "admin", "api", "supabase", "webhooks"]
    },
    {
      "review": "tenant-boundary",
      "skill": "saana-security-review",
      "reason": "Tenant-boundary sensitive admin restaurant slug route changed.",
      "match": ["admin/restaurants/[slug]", "app/api/admin/restaurants/[slug]"]
    },
    {
      "review": "vault-integrity",
      "skill": "vault-integrity-review",
      "reason": "Secrets, env vars, provider credentials, webhook secrets, or server-only key usage changed.",
      "match": [
        ".env",
        "env",
        "secret",
        "secrets",
        "token",
        "credential",
        "credentials",
        "SUPABASE_SERVICE_ROLE_KEY",
        "RESEND_API_KEY",
        "TWILIO_AUTH_TOKEN",
        "TWILIO_VERIFY_SERVICE_SID",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "GOOGLE_CLIENT_SECRET",
        "META",
        "WHATSAPP",
        "OPENAI_API_KEY",
        "service-role",
        "service_role",
        "webhook"
      ]
    },
    {
      "review": "runtime-binding",
      "skill": "runtime-binding-review",
      "reason": "Runtime binding, deployment target, Worker route, provider callback, or environment-specific wiring changed.",
      "match": [
        "wrangler",
        "cloudflare",
        "opennext",
        "open-next",
        "worker",
        "binding",
        "bindings",
        "route",
        "routes",
        "webhook",
        "callback",
        "queue",
        "r2",
        "d1",
        "kv",
        "bucket",
        "durable"
      ]
    },
    {
      "review": "vault-recovery",
      "skill": "vault-recovery-review",
      "reason": "Bootstrap, local env, recovery, vault, password manager, or deploy recovery process changed.",
      "match": [
        "bootstrap",
        "setup",
        "local",
        "env",
        "vault",
        "password-manager",
        "password_manager",
        "recovery",
        "onboarding",
        "deploy",
        "deployment",
        "README",
        "runbook"
      ]
    },
    {
      "review": "payments",
      "skill": "saana-payment-review",
      "reason": "Stripe, billing, checkout, payment, or pricing paths changed.",
      "match": ["stripe", "billing", "checkout", "payment", "payments", "pricing"]
    },
    {
      "review": "sms-compliance",
      "skill": "saana-sms-compliance-review",
      "reason": "Twilio, SMS, consent, IVR, or messaging paths changed.",
      "match": ["twilio", "sms", "consent", "ivr", "messaging", "messages"]
    },
    {
      "review": "restaurant-ux",
      "skill": "saana-restaurant-ux-review",
      "reason": "Restaurant, hub, cart, menu, orders, kitchen, or admin UI paths changed.",
      "match": ["app/r", "hub", "cart", "menu", "orders", "kitchen", "app/admin", "components/admin"]
    },
    {
      "review": "browser-qa",
      "skill": "saana-browser-qa",
      "reason": "UI, route, form, or page files changed.",
      "match": ["app", "pages", "routes", "forms", ".tsx", ".jsx"]
    },
    {
      "review": "deploy-canary",
      "skill": "saana-post-deploy-canary",
      "reason": "Wrangler, Cloudflare, environment, or deploy paths changed.",
      "match": ["wrangler", "cloudflare", "env", "deploy", "deployment", ".env"]
    }
  ],
  "confidence": {
    "deductions": [
      {
        "reason": "auth/session/tenant/security",
        "match": ["auth", "login", "session", "tenant", "security", "admin", "webhooks"],
        "amount": 0.2
      },
      {
        "reason": "payment/pricing",
        "match": ["stripe", "billing", "checkout", "payment", "payments", "pricing"],
        "amount": 0.2
      },
      {
        "reason": "sms/compliance",
        "match": ["twilio", "sms", "consent", "ivr", "messaging", "compliance"],
        "amount": 0.2
      },
      {
        "reason": "supabase/service-role/RLS",
        "match": ["supabase", "service-role", "service_role", "rls"],
        "amount": 0.15
      },
      {
        "reason": "deployment/env",
        "match": ["wrangler", "cloudflare", "deploy", "deployment", "env", ".env"],
        "amount": 0.15
      },
      {
        "reason": "vault/secrets/runtime",
        "match": ["secret", "secrets", "token", "credential", "env", "service-role", "service_role", "webhook"],
        "amount": 0.15
      },
      {
        "reason": "runtime/bindings/deploy wiring",
        "match": ["wrangler", "cloudflare", "binding", "bindings", "worker", "route", "webhook", "callback", "queue", "r2", "d1", "kv", "bucket"],
        "amount": 0.15
      },
      {
        "reason": "more than 10 files changed",
        "match": [],
        "condition": "changedFiles.length > 10",
        "amount": 0.1
      }
    ]
  },
  "autofixPolicy": {
    "allowed": [
      "lint",
      "type",
      "copy",
      "simple validation",
      "generic error message",
      "docs correction"
    ],
    "blocked": [
      "auth redesign",
      "tenant-boundary redesign",
      "destructive DB",
      "payment state rewrite",
      "live Stripe config",
      "Twilio/A2P changes",
      "secrets rotation",
      "production deploy",
      "broad refactor",
      "pricing/billing policy changes"
    ]
  }
}
